# ─────────────────────────────────────────────────────────────
# Le Parrain MCP — configuration d'exemple
# Copiez ce fichier en `.env` et remplissez les valeurs.
# NE COMMITEZ JAMAIS `.env` (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────

# Mode du backend de données :
#   "sample" → dataset d'exemple en mémoire (POC, aucune infra requise)
#   "api"    → tape l'API HTTP de leparrain.com (production, à venir)
LP_DATA_MODE=sample

# --- Mode "api" uniquement (laisser vide en POC) ---
# URL de base de l'API Le Parrain (jamais le repo source, juste l'API publique).
LP_API_BASE_URL=
# Clé API d'accès au backend Le Parrain (fournie côté serveur, jamais en dur).
LP_API_KEY=

# --- Identité de l'appelant (simulation POC) ---
# Si renseigné, l'appelant est "connecté" sous ce pseudo et ses liens publiés
# sont injectés en priorité. Si vide → appelant anonyme → lien plateforme par défaut.
LP_USER=

# Pseudo du propriétaire de la plateforme (lien par défaut servi aux anonymes).
LP_PLATFORM_OWNER=antoine
